<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_green" />
            <corners android:radius="20dp" />
            <size android:width="44dp" android:height="24dp" />
            <stroke android:width="1dp" android:color="@color/color_background_border_medium" />
        </shape>
    </item>
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_background_border_dark" />
            <corners android:radius="20dp" />
            <size android:width="44dp" android:height="24dp" />
            <stroke android:width="1dp" android:color="@color/color_background_border_medium" />
        </shape>
    </item>
</selector>